 # Using a clean vertical stack layout so the output is never cut off\n    with gr.Column():\n        user_input = gr.Textbox(\n            label=\"What information or guideline are you looking for?\", \n            placeholder=\"Type your question here (e.g., What are the standard working hours?) and press Enter...\"\n        )\n        submit_action = gr.Button(\"Search Guidelines System\", variant=\"primary\")\n        \n        gr.Markdown(\"### 📋 System Output:\")\n        # This will now display directly beneath the button cleanly\n        system_output = gr.Markdown(\"*System is idle. Type a query above to begin search...*\")\n            \n    # Hooking up the engine actions\n    submit_action.click(fn=process_rag_query, inputs=user_input, outputs=system_output)\n    user_input.submit(fn=process_rag_query, inputs=user_input, outputs=system_output)\n\n# Launching cleanly with public sharing link\napp_interface.launch(\n    inline=True, \n    share=True, \n    debug=False\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T20:59:04.712096Z","iopub.execute_input":"2026-06-09T20:59:04.712577Z","iopub.status.idle":"2026-06-09T20:59:07.650593Z"}},"outputs":[{"name":"stdout","text":"🌐 Building Web Application Graphical Layer...\n* Running on local URL:  http://127.0.0.1:7860\n* Running on public URL: https://072db287506540a579.gradio.live\n\nThis share link expires in 1 week. For free permanent hosting and GPU upgrades, run `gradio deploy` from the terminal in the working directory to deploy to Hugging Face Spaces (https://huggingface.co/spaces)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"<div><iframe src=\"https://072db287506540a579.gradio.live\" width=\"100%\" height=\"500\" allow=\"autoplay; camera; microphone; clipboard-read; clipboard-write;\" frameborder=\"0\" allowfullscreen></iframe></div>"},"metadata":{}},{"execution_count":7,"output_type":"execute_r