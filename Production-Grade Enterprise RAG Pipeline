    "# =====================================================================\n",
    "# CELL 3: DOCUMENT INGESTION, PARSING, AND PERSISTENT STORAGE\n",
    "# =====================================================================\n",
    "import os\n",
    "import chromadb\n",
    "from docling.document_converter import DocumentConverter\n",
    "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
    "\n",
    "# 1. Exact Kaggle path with the corrected dash (-) formatting\n",
    "source_doc = \"/kaggle/input/datasets/engrammarnasir7/company-rules1/company_rules.pdf\"\n",
    "KAGGLE_DB_DIR = \"/kaggle/working/chroma_db\"\n",
    "\n",
    "# Safety sanity check to confirm the dataset mounted successfully\n",
    "if not os.path.exists(source_doc):\n",
    "    raise FileNotFoundError(f\"❌ Could not find file at {source_doc}. Please double check your file name spelling.\")\n",
    "\n",
    "# 2. Document Processing Layout Parsing\n",
    "print(f\"📄 Parsing document semantics using Docling: {source_doc}...\")\n",
    "converter = DocumentConverter()\n",
    "conversion_result = converter.convert(source_doc)\n",
    "markdown_payload = conversion_result.document.export_to_markdown()\n",
    "\n",
    "print(\"✂️ Fragmenting markdown nodes into isolated text boundaries...\")\n",
    "text_splitter = RecursiveCharacterTextSplitter(chunk_size=550, chunk_overlap=110)\n",
    "data_chunks = text_splitter.split_text(markdown_payload)\n",
    "\n",
    "print(\"📦 Structuring persistent vector tables inside Kaggle Working Directory...\")\n",
    "chroma_client = chromadb.PersistentClient(path=KAGGLE_DB_DIR)\n",
    "policy_collection = chroma_client.get_or_create_collection(name=\"internal_company_rules\")\n",
    "\n",
    "docs_batch = []\n",
    "vectors_batch = []\n",
    "ids_batch = []\n",
    "\n",
    "print(\"🧠 Vectorizing structural compliance chunks...\")\n",
    "for index, chunk in enumerate(data_chunks):\n",
    "    vector_representation = embedding_model.encode(chunk).tolist()\n",
    "    docs_batch.append(chunk)\n",
    "    vectors_batch.append(vector_representation)\n",
    "    ids_batch.append(f\"doc_node_{index}\")\n",
    "\n",
