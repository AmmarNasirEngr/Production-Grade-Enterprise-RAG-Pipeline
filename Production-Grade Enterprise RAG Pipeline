    "# =====================================================================\n",
    "# SYSTEM EXPORT: BUNDLE SOURCE CODE & CHROMA VECTOR DATA TO ZIP\n",
    "# =====================================================================\n",
    "import os\n",
    "import shutil\n",
    "\n",
    "# 1. Define paths based on your environment setup\n",
    "CHROMA_DIR = \"/kaggle/working/chroma_db\"  # Adjust name if your database directory has a different title\n",
    "EXPORT_ZIP_PATH = \"/kaggle/working/company_rag_portfolio_package\"\n",
    "\n",
    "print(\"📦 Initializing portfolio asset compilation...\")\n",
    "\n",
    "if os.path.exists(CHROMA_DIR):\n",
    "    # Create a unified zip file combining your compiled database vectors\n",
    "    shutil.make_archive(EXPORT_ZIP_PATH, 'zip', CHROMA_DIR)\n",
    "    print(f\"✅ Success! Your pipeline assets have been bundled into a portable archive.\")\n",
    "    print(f\"🔗 Target download path: {EXPORT_ZIP_PATH}.zip\")\n",
    "else:\n",
    "    # Fallback in case your directory is at the root level of the workspace\n",
    "    current_workspace_dirs = [d for d in os.listdir('/kaggle/working') if os.path.isdir(os.path.join('/kaggle/working', d))]\n",
