es into isolated text boundaries...\")\ntext_splitter = RecursiveCharacterTextSplitter(chunk_size=550, chunk_overlap=110)\ndata_chunks = text_splitter.split_text(markdown_payload)\n\nprint(\"📦 Structuring persistent vector tables inside Kaggle Working Directory...\")\nchroma_client = chromadb.PersistentClient(path=KAGGLE_DB_DIR)\npolicy_collection = chroma_client.get_or_create_collection(name=\"internal_company_rules\")\n\ndocs_batch = []\nvectors_batch = []\nids_batch = []\n\nprint(\"🧠 Vectorizing structural compliance chunks...\")\nfor index, chunk in enumerate(data_chunks):\n    vector_representation = embedding_model.encode(chunk).tolist()\n    docs_batch.append(chunk)\n    vectors_batch.append(vector_representation)\n    ids_batch.append(f\"doc_node_{index}\")\n\n# Commit batches to memory disk structure\npolicy_collection.add(\n    embeddings=vectors_batch,\n    documents=docs_batch,\n    ids=ids_batch\n)\nprint(f\"✅ Successfully written {len(data_chunks)} rule nodes into persistent Kaggle storage!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T20:51:21.099672Z","iopub.execute_input":"2026-06-09T20:51:21.100299Z","iopub.status.idle":"2026-06-09T20:57:18.117508Z","shell.execute_reply.started":"2026-06-09T20:51:21.100266Z","shell.execute_reply":"2026-06-09T20:57:18.115923Z"}},"outputs":[{"name":"stdout","text":"📄 Parsing document semantics using Docling: /kaggle/input/datasets/engrammarnasir7/company-rules1/company_rules.pdf...\n","output_type":"stream"},{"name":"stderr","text":"\u001b[32m[INFO] 2026-06-09 20:51:22,548 [RapidOCR] base.py:22: Using engine_name: onnxruntime\u001b[0m\n\u001b[32m[INFO] 2026-06-09 20:51:22,554 [RapidOCR] download_file.py:68: Initiating download: https://www.modelscope.cn/models/RapidAI/RapidOCR/resolve/v3.8.0/onnx/PP-OCRv4/det/ch_PP-OCRv4_det_mobile.onnx\u001b[0m\n\u001b[32m[INFO] 2026-06-09 20:51:23,264 [RapidOCR] download_file.py:82: Download size: 4.53MB\u001b[0m\n\u001b[32m[INFO] 2026-06-09 20:51:23,3